#!/usr/bin/env python3

import argparse
import threading
import time
from dataclasses import dataclass
from typing import Optional

import serial


# =========================================================
# Protocol constants
# =========================================================

HEADER = 0xCC

MSG_WRITE = 0x01
MSG_READ = 0x02

MSG_ACK = 0x02
MSG_EVENT = 0x03


# =========================================================
# Register map
# =========================================================

REGISTERS = {

    # System
    "sync_led": 0x01,

    # Sensors
    "door_sensor": 0x02,
    "table_sensor": 0x03,

    # Cameras
    "cam_a": 0x04,
    "cam_b": 0x05,

    # Door
    "door_status": 0x10,
    "door_command": 0x11,

    # Table
    "table_status": 0x18,
    "table_command": 0x19,

    # Port A
    "led_a": 0x21,
    "valve_a": 0x22,
    "ir_a": 0x23,

    # Port B
    "led_b": 0x24,
    "valve_b": 0x25,
    "ir_b": 0x26,

    # Port C
    "led_c": 0x27,
    "valve_c": 0x28,
    "ir_c": 0x29,
}

REGISTER_NAMES = {v: k for k, v in REGISTERS.items()}


# =========================================================
# Packet structure
# =========================================================

@dataclass
class Packet:
    register: int
    msg_type: int
    value: int

    def encode(self) -> bytes:
        return bytes([
            HEADER,
            self.register,
            self.msg_type,
            self.value,
        ])

    @staticmethod
    def decode(data: bytes) -> "Packet":

        if len(data) != 4:
            raise ValueError("Packet must be 4 bytes")

        if data[0] != HEADER:
            raise ValueError(f"Invalid header: {hex(data[0])}")

        return Packet(
            register=data[1],
            msg_type=data[2],
            value=data[3],
        )


# =========================================================
# Serial helpers
# =========================================================

def transmit_packet(ser: serial.Serial, packet: Packet):

    raw = packet.encode()

    ser.write(raw)
    ser.flush()

    print(f"[TX] {[hex(x) for x in raw]}")


def receive_packet(ser: serial.Serial) -> Optional[Packet]:

    data = ser.read(4)

    if len(data) != 4:
        return None

    try:
        return Packet.decode(data)

    except Exception as e:
        print(f"[RX ERROR] {e}")
        return None


# =========================================================
# Event monitor thread
# =========================================================

def monitor_loop(ser: serial.Serial, stop_flag: threading.Event):

    while not stop_flag.is_set():

        packet = receive_packet(ser)

        if packet is None:
            continue

        reg_name = REGISTER_NAMES.get(packet.register, hex(packet.register))

        if packet.msg_type == MSG_ACK:
            msg = "ACK"

        elif packet.msg_type == MSG_EVENT:
            msg = "EVENT"

        else:
            msg = f"UNKNOWN({packet.msg_type})"

        print(
            f"\n[{msg}] "
            f"{reg_name} "
            f"value={packet.value}"
        )

        print("> ", end="", flush=True)


# =========================================================
# High-level CLI functions
# =========================================================

def write_register(ser, register_name, value):

    packet = Packet(
        register=REGISTERS[register_name],
        msg_type=MSG_WRITE,
        value=value,
    )

    transmit_packet(ser, packet)


def read_register(ser, register_name):

    packet = Packet(
        register=REGISTERS[register_name],
        msg_type=MSG_READ,
        value=0,
    )

    transmit_packet(ser, packet)


# =========================================================
# CLI parser
# =========================================================

def handle_command(ser, text: str):

    tokens = text.strip().lower().split()

    if not tokens:
        return

    cmd = tokens[0]

    # -----------------------------------------------------
    # LED control
    # -----------------------------------------------------

    if cmd == "led":

        # examples:
        # led a on
        # led b off

        if len(tokens) != 3:
            print("Usage: led [a|b|c] [on|off]")
            return

        port = tokens[1]
        state = tokens[2]

        reg = f"led_{port}"

        value = 1 if state == "on" else 0

        write_register(ser, reg, value)
        return

    # -----------------------------------------------------
    # Valve control
    # -----------------------------------------------------

    if cmd == "valve":

        if len(tokens) != 3:
            print("Usage: valve [a|b|c] [on|off]")
            return

        port = tokens[1]
        state = tokens[2]

        reg = f"valve_{port}"

        value = 1 if state == "on" else 0

        write_register(ser, reg, value)
        return

    # -----------------------------------------------------
    # Door control
    # -----------------------------------------------------

    if cmd == "door":

        if len(tokens) != 2:
            print("Usage: door [open|close|stop]")
            return

        action = tokens[1]

        values = {
            "open": 0,
            "close": 1,
            "stop": 2,
        }

        if action not in values:
            print("Invalid door command")
            return

        write_register(ser, "door_command", values[action])
        return

    # -----------------------------------------------------
    # Table control
    # -----------------------------------------------------

    if cmd == "table":

        # table cw 4
        # table ccw 2

        if len(tokens) != 3:
            print("Usage: table [cw|ccw] position")
            return

        direction = tokens[1]
        position = int(tokens[2])

        if not 0 <= position <= 127:
            print("Position must be 0-127")
            return

        value = position

        if direction == "ccw":
            value |= 0x80

        write_register(ser, "table_command", value)
        return


# =========================================================
# Main
# =========================================================

def main(argv=None):

    parser = argparse.ArgumentParser()

    parser.add_argument("--port", required=True)
    parser.add_argument("--baud", type=int, default=115200)
    parser.add_argument("--timeout", type=float, default=0.1)
    parser.add_argument("--startup-delay", type=float, default=2.0)

    args = parser.parse_args(argv)

    ser = serial.Serial(
        port=args.port,
        baudrate=args.baud,
        timeout=args.timeout,
        write_timeout=1.0,
    )

    time.sleep(args.startup_delay)

    print(f"[INFO] Connected to {args.port}")

    stop_flag = threading.Event()

    monitor_thread = threading.Thread(
        target=monitor_loop,
        args=(ser, stop_flag),
        daemon=True,
    )

    monitor_thread.start()

    print("\nExample Commands:")
    print("  led a on")
    print("  valve b off")
    print("  door open")
    print("  table cw 4")
    print("  quit\n")

    try:

        while True:

            user = input("> ").strip()

            if user.lower() in ("q", "quit", "exit"):
                break

            handle_command(ser, user)

    except KeyboardInterrupt:
        pass

    finally:

        stop_flag.set()

        try:
            ser.close()
        except Exception:
            pass

        print("\n[INFO] Disconnected")


if __name__ == "__main__":
    raise SystemExit(main())
